{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JudgeOutput",
  "description": "Judge 决策输出格式",
  "type": "object",
  "required": ["action"],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["REPLY", "REPLY_PRO", "IGNORE", "REJECT"],
      "description": "决策动作"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "决策置信度"
    },
    "reasoning": {
      "type": "string",
      "description": "决策理由（可选，用于调试）",
      "maxLength": 500
    }
  },
  "additionalProperties": false
}
