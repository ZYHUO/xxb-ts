# ============================================================
# xxb-ts 环境变量模板
# 复制为 .env 并填写实际值
# ============================================================

# --- Telegram Bot (required) ---
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
BOT_USERNAME=xxb_bot

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379/0

# --- SQLite ---
SQLITE_PATH=./data/xxb.db

# --- Knowledge base (per-chat .md files, PHP parity) ---
# KNOWLEDGE_BASE_DIR=./data/knowledge
# JUDGE_KNOWLEDGE_ENABLED=false
# JUDGE_KNOWLEDGE_PERMANENT=true
# JUDGE_KNOWLEDGE_GROUP=true

# --- Knowledge cron (AI refresh of group .md; set chat IDs to enable) ---
# KNOWLEDGE_CRON_CHAT_IDS=-1001234567890
# KNOWLEDGE_CRON_SCHEDULE=30 * * * *
# KNOWLEDGE_CRON_HASH_PATH=./data/knowledge-cron-hashes.json

# --- Per-user persona files: prompts/persona/{uid}.md or .txt ---
# PERSONA_DIR=prompts/persona

# --- AI Provider (OpenAI-compatible, required) ---
# reply / reply_pro / vision 始终走这里（保持 Gemini 等主力模型）
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=sk-your-api-key-here
AI_MODEL_JUDGE=gpt-4o-mini
AI_MODEL_REPLY=gpt-4o-mini
AI_MODEL_REPLY_PRO=gpt-4o
AI_MODEL_VISION=gpt-4o
AI_MODEL_SUMMARIZE=gpt-4o-mini
AI_MODEL_ALLOWLIST_REVIEW=gpt-4o-mini

# --- 本地模型 (Qwen / GLM 等，OpenAI-compatible，无 NSFW/政治内容) ---
# 用于: judge（判断是否回复）、summarize（知识库摘要）、allowlist_review（入群审核）
# 不设置则自动回退到主 provider
# LOCAL_AI_BASE_URL=http://127.0.0.1:8317/v1
# LOCAL_AI_API_KEY=local-key
# LOCAL_AI_MODEL_JUDGE=glm-5            # 判断是否回复：用不带 think 的快模型，否则 think 过程白白加延迟
# LOCAL_AI_MODEL_SUMMARIZE=qwen3.6-plus # 知识库摘要：think 有帮助，不在意时间
# LOCAL_AI_MODEL_ALLOWLIST=qwen3.6-plus # 入群审核：需要推理，think 有帮助

# --- Server ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# --- Webhook (optional — uses polling if not set) ---
# WEBHOOK_URL=https://your-domain.com/webhook
# WEBHOOK_SECRET=your-webhook-secret

# --- Queue ---
QUEUE_CONCURRENCY=20

# --- AI Tuning ---
HEDGE_DELAY_MS=2000

# --- Rate Limiting ---
RATE_LIMIT_PER_MIN=30

# --- Streaming ---
STREAMING_MIN_INTERVAL=500
STREAMING_MIN_CHARS=50

# --- Tool System (optional) ---
# SEARXNG_URL=http://localhost:8080
# FETCH_GATEWAY_URL=
# FETCH_WORKER_URL=https://your-fetch-worker.example.com
# WEB_FETCH_USER_AGENT=XXB-WebFetch/1.0
# IP_QUALITY_API_URL=https://your-ip-quality-api.example.com
# TIMER_API_URL=https://your-timer-api.example.com
# TIMER_CALLBACK_URL=https://your-callback-url.example.com
# COMMON_API_KEY=your-common-api-key

# --- ChromaDB 长期记忆 (可选，不配置则语义搜索返回空) ---
# CHROMA_HOST=localhost
# CHROMA_PORT=8400

# --- Tracking ---
OUTCOME_TRACKING_ENABLED=false

# --- Business ---
MASTER_UID=0
BOT_NICKNAMES=xxb,啾咪囝
CONTEXT_MAX_LENGTH=600
JUDGE_WINDOW_SIZE=10

# --- Allowlist ---
ALLOWLIST_ENABLED=false
ALLOWLIST_REDIS_PREFIX=xxb:mal:
ALLOWLIST_DEFAULT_ENABLE_AFTER_APPROVE=false
ALLOWLIST_MAX_SUBMISSIONS_PER_DAY=20
ALLOWLIST_AUTO_AI_REVIEW=true
ALLOWLIST_AI_MESSAGE_LIMIT=100
ALLOWLIST_AI_CONTEXT_MAX_CHARS=24000
ALLOWLIST_AI_AUTO_ENABLE=true
ALLOWLIST_AI_CONFIDENCE_THRESHOLD=0.85

# --- Cutover (required for scripts/cutover.sh) ---
# TS_WEBHOOK_URL=https://your-ts-domain.com/webhook
# PHP_WEBHOOK_URL=https://your-php-domain.com/webhook
# ADMIN_CORS_ORIGINS=http://localhost:5173,https://admin.example.com
