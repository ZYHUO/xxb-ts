# ============================================================
# xxb-ts 环境变量模板
# 复制为 .env 并填写实际值
# ============================================================

# --- Telegram Bot (required) ---
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
BOT_USERNAME=xxb_bot

# --- Redis ---
REDIS_URL=redis://127.0.0.1:6379/0

# --- SQLite ---
SQLITE_PATH=./data/xxb.db

# --- Knowledge base (per-chat .md files, PHP parity) ---
# KNOWLEDGE_BASE_DIR=./data/knowledge
# JUDGE_KNOWLEDGE_ENABLED=false
# JUDGE_KNOWLEDGE_PERMANENT=true
# JUDGE_KNOWLEDGE_GROUP=true

# --- Knowledge cron (AI refresh of group .md; set chat IDs to enable) ---
# KNOWLEDGE_CRON_CHAT_IDS=-1001234567890
# KNOWLEDGE_CRON_SCHEDULE=30 * * * *
# KNOWLEDGE_CRON_HASH_PATH=./data/knowledge-cron-hashes.json

# --- Per-user persona files: prompts/persona/{uid}.md or .txt ---
# PERSONA_DIR=prompts/persona

# --- AI Providers / Routing (required) ---
# 每个 provider = endpoint + key + model；usage 决定各场景走哪个 provider label
AI_PROVIDER_REPLY_ENDPOINT=https://api.openai.com/v1
AI_PROVIDER_REPLY_KEY=***
AI_PROVIDER_REPLY_MODEL=gpt-4o-mini
AI_PROVIDER_REPLY_PRO_ENDPOINT=https://api.openai.com/v1
AI_PROVIDER_REPLY_PRO_KEY=***
AI_PROVIDER_REPLY_PRO_MODEL=gpt-4o
AI_PROVIDER_VISION_ENDPOINT=https://api.openai.com/v1
AI_PROVIDER_VISION_KEY=***
AI_PROVIDER_VISION_MODEL=gpt-4o
AI_PROVIDER_JUDGE_ENDPOINT=https://api.openai.com/v1
AI_PROVIDER_JUDGE_KEY=***
AI_PROVIDER_JUDGE_MODEL=gpt-4o-mini
AI_PROVIDER_SUMMARIZE_ENDPOINT=https://api.openai.com/v1
AI_PROVIDER_SUMMARIZE_KEY=***
AI_PROVIDER_SUMMARIZE_MODEL=gpt-4o-mini
AI_PROVIDER_ALLOWLIST_REVIEW_ENDPOINT=https://api.openai.com/v1
AI_PROVIDER_ALLOWLIST_REVIEW_KEY=***
AI_PROVIDER_ALLOWLIST_REVIEW_MODEL=gpt-4o-mini
AI_USAGE_REPLY_LABEL=reply
AI_USAGE_REPLY_PRO_LABEL=reply_pro
AI_USAGE_VISION_LABEL=vision
AI_USAGE_JUDGE_LABEL=judge
AI_USAGE_SUMMARIZE_LABEL=summarize
AI_USAGE_ALLOWLIST_REVIEW_LABEL=allowlist_review
AI_USAGE_PATH_REFLECTION_LABEL=judge
AI_USAGE_REPLY_SPLITTER_LABEL=reply

# 兼容旧配置：AI_BASE_URL / AI_MODEL_* / LOCAL_AI_* 仍可继续使用，但新部署建议直接改成上面的 AI_PROVIDER_* / AI_USAGE_*。

# --- 本地模型 (Qwen / GLM 等，OpenAI-compatible，无 NSFW/政治内容) ---
# 用于: judge / summarize / allowlist_review；不设置则继续走上面的 provider
# AI_PROVIDER_LOCAL_JUDGE_ENDPOINT=http://127.0.0.1:8317/v1
# AI_PROVIDER_LOCAL_JUDGE_KEY=***
# AI_PROVIDER_LOCAL_JUDGE_MODEL=glm-5
# AI_USAGE_JUDGE_LABEL=local_judge
# AI_PROVIDER_LOCAL_SUMMARIZE_ENDPOINT=http://127.0.0.1:8317/v1
# AI_PROVIDER_LOCAL_SUMMARIZE_KEY=***
# AI_PROVIDER_LOCAL_SUMMARIZE_MODEL=qwen3.6-plus
# AI_USAGE_SUMMARIZE_LABEL=local_summarize
# AI_PROVIDER_LOCAL_ALLOWLIST_REVIEW_ENDPOINT=http://127.0.0.1:8317/v1
# AI_PROVIDER_LOCAL_ALLOWLIST_REVIEW_KEY=***
# AI_PROVIDER_LOCAL_ALLOWLIST_REVIEW_MODEL=qwen3.6-plus
# AI_USAGE_ALLOWLIST_REVIEW_LABEL=local_allowlist_review

# --- Server ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# --- Webhook (optional — uses polling if not set) ---
# WEBHOOK_URL=https://your-domain.com/webhook
# WEBHOOK_SECRET=your-webhook-secret

# --- Queue ---
QUEUE_CONCURRENCY=20

# --- AI Tuning ---
HEDGE_DELAY_MS=2000

# --- Rate Limiting ---
RATE_LIMIT_PER_MIN=30

# --- Streaming ---
STREAMING_MIN_INTERVAL=500
STREAMING_MIN_CHARS=50

# --- Tool System (optional) ---
# SEARXNG_URL=http://localhost:8080
# FETCH_GATEWAY_URL=
# FETCH_WORKER_URL=https://your-fetch-worker.example.com
# WEB_FETCH_USER_AGENT=XXB-WebFetch/1.0
# IP_QUALITY_API_URL=https://your-ip-quality-api.example.com
# TIMER_API_URL=https://your-timer-api.example.com
# TIMER_CALLBACK_URL=https://your-callback-url.example.com
# COMMON_API_KEY=your-common-api-key

# --- ChromaDB 长期记忆 (可选，不配置则语义搜索返回空) ---
# CHROMA_HOST=localhost
# CHROMA_PORT=8400

# --- Tracking ---
OUTCOME_TRACKING_ENABLED=false

# --- Business ---
MASTER_UID=0
BOT_NICKNAMES=xxb,啾咪囝
CONTEXT_MAX_LENGTH=600
JUDGE_WINDOW_SIZE=10

# --- Allowlist ---
ALLOWLIST_ENABLED=false
ALLOWLIST_REDIS_PREFIX=xxb:mal:
ALLOWLIST_DEFAULT_ENABLE_AFTER_APPROVE=false
ALLOWLIST_MAX_SUBMISSIONS_PER_DAY=20
ALLOWLIST_AUTO_AI_REVIEW=true
ALLOWLIST_AI_MESSAGE_LIMIT=100
ALLOWLIST_AI_CONTEXT_MAX_CHARS=24000
ALLOWLIST_AI_AUTO_ENABLE=true
ALLOWLIST_AI_CONFIDENCE_THRESHOLD=0.85

# --- Cutover (required for scripts/cutover.sh) ---
# TS_WEBHOOK_URL=https://your-ts-domain.com/webhook
# PHP_WEBHOOK_URL=https://your-php-domain.com/webhook
# ADMIN_CORS_ORIGINS=http://localhost:5173,https://admin.example.com

# ── Channel Source (频道消息源，存入 ChromaDB 作为 AI 知识) ──
# 逗号分隔的频道 ID（负数），bot 需要是频道管理员
# CHANNEL_SOURCE_IDS=-1001234567890,-1009876543210
CHANNEL_SOURCE_IDS=