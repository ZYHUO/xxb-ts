{
  "name": "xxb-ts",
  "version": "0.1.0",
  "description": "啾咪囝 Telegram AI 群聊喵娘机器人 — TypeScript 重写",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "build:miniapp": "npm --prefix miniapp-web run build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:miniapp": "npm --prefix miniapp-web run test",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write ."
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@grammyjs/runner": "^2.0.3",
    "@hono/node-server": "^1.14.1",
    "@xenova/transformers": "^2.17.2",
    "ai": "^4.3.16",
    "better-sqlite3": "^11.9.1",
    "bullmq": "^5.52.0",
    "chromadb": "^3.4.3",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "grammy": "^1.35.0",
    "hono": "^4.7.10",
    "ioredis": "^5.6.1",
    "lru-cache": "^11.1.0",
    "nanoid": "^5.1.5",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "tiktoken": "^1.0.21",
    "zod": "^3.25.34"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.21",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9.27.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
